/**
 * SDT Navigator: list all content controls (SDTs) in a document and focus them.
 *
 * This demo shows how to:
 * - Use `editor.doc.contentControls.list()` to enumerate all SDTs in a document
 * - Use `ui.contentControls.focus()` to scroll and place the caret inside an SDT
 *
 * The sidebar lists every SDT with its alias, tag, type (block/inline), and lock mode.
 * Click any card or the "Focus" button to scroll to the SDT and place the caret inside.
 */

import { SuperDoc } from 'superdoc';
import { createSuperDocUI } from 'superdoc/ui';
import 'superdoc/style.css';
import './style.css';

type NodeKind = 'block' | 'inline';
type LockMode = 'unlocked' | 'sdtLocked' | 'contentLocked' | 'sdtContentLocked';
type ContentControlTarget = { kind: NodeKind; nodeType: 'sdt'; nodeId: string };

type ContentControlInfo = {
  target: ContentControlTarget;
  controlType: string;
  lockMode: LockMode;
  properties?: { tag?: string; alias?: string };
  text?: string;
};

type DocumentApi = {
  contentControls: {
    list(input?: Record<string, unknown>): { items: ContentControlInfo[]; total: number };
  };
};

type DemoEditor = { doc: DocumentApi };
type DemoSuperDoc = SuperDoc & { activeEditor: DemoEditor | null };

// ===========================================================================
// KEY API: Scrolling to Content Controls
// ===========================================================================
//
// This is the main API for scrolling to and focusing SDTs in a document.
// Use `ui.contentControls.focus()` to scroll an SDT into view AND place the
// caret inside it.
//
// Usage:
//   const ui = createSuperDocUI({ superdoc });
//   await ui.contentControls.focus({ id: nodeId, block: 'center' });
//
// Parameters:
//   - id: The SDT's nodeId (from contentControls.list() or events)
//   - block: Scroll alignment - 'center', 'start', 'end', or 'nearest'
//
// Alternative (scroll only, no caret placement):
//   await ui.contentControls.scrollIntoView({ id: nodeId, block: 'center' });
//
// ===========================================================================

/**
 * Focus an SDT: scroll it into view and place the caret inside.
 * This is the key function demonstrating the scrolling API.
 */
function focusSdt(nodeId: string): void {
  if (!state.ui) return;
  state.activeId = nodeId;
  highlightActive();
  // The key API call - scroll to the SDT and focus it
  void state.ui.contentControls.focus({ id: nodeId, block: 'center' });
}

// ---------------------------------------------------------------------------
// State and DOM
// ---------------------------------------------------------------------------

const state = {
  editor: null as DemoEditor | null,
  ui: null as ReturnType<typeof createSuperDocUI> | null,
  sdts: [] as ContentControlInfo[],
  activeId: null as string | null,
};

const statusEl = qs<HTMLElement>('#status');
const summaryEl = qs<HTMLElement>('#summary');
const sdtListEl = qs<HTMLElement>('#sdt-list');
const searchEl = qs<HTMLInputElement>('#search');
const refreshBtn = qs<HTMLButtonElement>('#refresh');

setBusy(true);

const superdoc = new SuperDoc({
  selector: '#editor',
  documentMode: 'editing',
  document: '/nda-template.docx',
  modules: {
    comments: false,
    toolbar: { selector: '#superdoc-toolbar', responsiveToContainer: true },
  },
  telemetry: { enabled: false },
  onReady: ({ superdoc: sd }) => void initialize(sd as DemoSuperDoc),
});

// ---------------------------------------------------------------------------
// Initialize
// ---------------------------------------------------------------------------

async function initialize(instance: DemoSuperDoc): Promise<void> {
  if (!instance.activeEditor?.doc) {
    setStatus('Document API unavailable');
    return;
  }
  state.editor = instance.activeEditor;
  state.ui = createSuperDocUI({ superdoc: instance });

  // Sync document selection to sidebar highlight
  instance.on('content-control:click', ({ target }: { target: { nodeId?: string } }) => {
    state.activeId = target?.nodeId ?? null;
    highlightActive();
  });
  instance.on('content-control:active-change', ({ active }: { active: { nodeId?: string } | null }) => {
    if (!active) {
      state.activeId = null;
      highlightActive();
    }
  });

  refreshList();
  setStatus('Ready');
  setBusy(false);
}

// ---------------------------------------------------------------------------
// SDT listing
// ---------------------------------------------------------------------------

function refreshList(): void {
  const doc = state.editor?.doc;
  if (!doc) return;

  const result = doc.contentControls.list({});
  state.sdts = result.items;
  renderList();
  refreshSummary();
}

function renderList(): void {
  const query = searchEl.value.trim().toLowerCase();
  sdtListEl.innerHTML = '';

  const filtered = state.sdts.filter((sdt) => {
    if (!query) return true;
    const alias = (sdt.properties?.alias ?? '').toLowerCase();
    const tag = (sdt.properties?.tag ?? '').toLowerCase();
    const text = (sdt.text ?? '').toLowerCase();
    return alias.includes(query) || tag.includes(query) || text.includes(query);
  });

  if (filtered.length === 0) {
    sdtListEl.innerHTML = '<p class="empty">No content controls found</p>';
    return;
  }

  for (const sdt of filtered) {
    const card = createSdtCard(sdt);
    sdtListEl.appendChild(card);
  }

  highlightActive();
}

function createSdtCard(sdt: ContentControlInfo): HTMLElement {
  const card = document.createElement('article');
  card.className = 'sdt-card' + (sdt.target.nodeId === state.activeId ? ' is-active' : '');
  card.dataset.nodeId = sdt.target.nodeId;

  const alias = sdt.properties?.alias || '(no alias)';
  const tag = sdt.properties?.tag || '(no tag)';
  const preview = truncate(sdt.text ?? '', 50);
  const kind = sdt.target.kind;
  const lockMode = formatLockMode(sdt.lockMode);

  card.innerHTML = `
    <div class="sdt-card-header">
      <h3 class="sdt-alias">${escapeHtml(alias)}</h3>
      <span class="sdt-kind ${kind}">${kind}</span>
    </div>
    <p class="sdt-preview">${escapeHtml(preview)}</p>
    <div class="sdt-meta">
      <span class="sdt-lock">${escapeHtml(lockMode)}</span>
      <span class="sdt-tag" title="${escapeAttr(tag)}">${escapeHtml(truncate(tag, 30))}</span>
    </div>
    <div class="sdt-actions">
      <button class="focus-btn" type="button">Focus</button>
    </div>
  `;

  card.querySelector('.focus-btn')?.addEventListener('click', (e) => {
    e.stopPropagation();
    focusSdt(sdt.target.nodeId);
  });

  card.addEventListener('click', () => {
    focusSdt(sdt.target.nodeId);
  });

  return card;
}

function highlightActive(): void {
  sdtListEl.querySelectorAll<HTMLElement>('.sdt-card').forEach((card) => {
    card.classList.toggle('is-active', card.dataset.nodeId === state.activeId);
  });
}

// ---------------------------------------------------------------------------
// Event handlers
// ---------------------------------------------------------------------------

searchEl.addEventListener('input', () => {
  renderList();
});

refreshBtn.addEventListener('click', () => {
  refreshList();
  setStatus('List refreshed');
});

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function refreshSummary(): void {
  const total = state.sdts.length;
  const blocks = state.sdts.filter((s) => s.target.kind === 'block').length;
  const inlines = state.sdts.filter((s) => s.target.kind === 'inline').length;
  summaryEl.textContent = `${total} SDTs (${blocks} block, ${inlines} inline)`;
}

function formatLockMode(mode: LockMode): string {
  switch (mode) {
    case 'unlocked':
      return 'Unlocked';
    case 'sdtLocked':
      return 'SDT Locked';
    case 'contentLocked':
      return 'Content Locked';
    case 'sdtContentLocked':
      return 'Both Locked';
    default:
      return mode;
  }
}

function truncate(s: string, maxLen: number): string {
  if (s.length <= maxLen) return s;
  return s.slice(0, maxLen - 1) + '\u2026';
}

function setBusy(busy: boolean): void {
  document.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
    b.disabled = busy;
  });
}

function setStatus(text: string): void {
  statusEl.textContent = text;
}

function qs<T extends Element>(selector: string): T {
  const element = document.querySelector<T>(selector);
  if (!element) throw new Error(`Missing element ${selector}`);
  return element;
}

function escapeHtml(s: string): string {
  return s.replace(/[&<>"]/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[ch]!);
}

function escapeAttr(s: string): string {
  return escapeHtml(s).replace(/'/g, '&#39;');
}

// ---------------------------------------------------------------------------
// Debug / teardown
// ---------------------------------------------------------------------------

(window as unknown as { __demo: unknown }).__demo = {
  superdoc,
  state,
  doc: () => state.editor?.doc ?? null,
};

const teardown = () => {
  try {
    state.ui?.destroy();
  } catch {
    /* best-effort teardown */
  }
  state.ui = null;
  superdoc.destroy();
};
window.addEventListener('beforeunload', teardown);
if (import.meta.hot) import.meta.hot.dispose(teardown);
